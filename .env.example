# Secret used to sign session cookies. Set to a long random string in production.
SESSION_SECRET=change-me

# Optional: SMTP delivery for magic sign-in links.
# If SMTP_HOST is unset, magic links are printed to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false # Set to true if using port 465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Tarok <no-reply@localhost>
